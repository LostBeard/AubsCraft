{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Rcon": {
    "Host": "127.0.0.1",
    "Port": 25575,
    "Password": "YOUR_RCON_PASSWORD"
  },
  "Minecraft": {
    "ServerPath": "/opt/minecraft/server",
    "LogPath": "/opt/minecraft/server/logs/latest.log",
    "PluginsPath": "/opt/minecraft/server/plugins",
    "GameVersion": "1.21.5",
    "ServiceName": "minecraft"
  },
  "BlueMap": {
    "Url": "",
    "Enabled": false
  },
  "ActivityLog": {
    "MaxEvents": 1000,
    "FilePath": "activity-log.json"
  },
  "Auth": {
    "CredentialsPath": "admin.json"
  }
}
