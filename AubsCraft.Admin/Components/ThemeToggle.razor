@inject SpawnDev.BlazorJS.BlazorJSRuntime JS
@using SpawnDev.BlazorJS.JSObjects

<button class="btn btn-sm btn-outline-secondary" @onclick="ToggleAsync" title="Toggle theme">
    @(_isDark ? "Light" : "Dark")
</button>

@code {
    private bool _isDark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = JS.Call<string>("themeInterop.getTheme");
            _isDark = theme == "dark";
            StateHasChanged();
        }
        await Task.CompletedTask;
    }

    private Task ToggleAsync()
    {
        _isDark = !_isDark;
        JS.CallVoid("themeInterop.setTheme", _isDark ? "dark" : "light");
        return Task.CompletedTask;
    }
}
