@page "/plugins"
@inject ServerHubClient Hub

<PageTitle>Plugins - AubsCraft Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Plugins</h1>
    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-success" @onclick="StartServerAsync" disabled="@_controlBusy">
            @(_controlAction == "start" ? "Starting..." : "Start")
        </button>
        <button class="btn btn-sm btn-warning" @onclick="RestartServerAsync" disabled="@_controlBusy">
            @(_controlAction == "restart" ? "Restarting..." : "Restart")
        </button>
        <button class="btn btn-sm btn-danger" @onclick="StopServerAsync" disabled="@_controlBusy">
            @(_controlAction == "stop" ? "Stopping..." : "Stop")
        </button>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(_tab == "installed" ? "active" : "")" @onclick='() => _tab = "installed"'>
            Installed (@_plugins.Count)
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_tab == "browse" ? "active" : "")" @onclick='() => _tab = "browse"'>
            Browse Modrinth
        </button>
    </li>
</ul>

@if (_tab == "installed")
{
    <p class="text-muted mb-3">@_plugins.Count(p => p.Enabled) enabled, @_plugins.Count(p => !p.Enabled) disabled.</p>

    <div class="row">
        @foreach (var plugin in _plugins.OrderBy(p => p.Name))
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card @(plugin.Enabled ? "" : "opacity-50")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="card-title mb-1">
                                    @plugin.Name
                                    @if (!string.IsNullOrEmpty(plugin.Version))
                                    {
                                        <small class="text-muted">v@plugin.Version</small>
                                    }
                                </h6>
                                @if (!string.IsNullOrEmpty(plugin.Description))
                                {
                                    <p class="card-text text-muted small mb-1" style="line-height: 1.3;">@Truncate(plugin.Description, 100)</p>
                                }
                                @if (!string.IsNullOrEmpty(plugin.Authors))
                                {
                                    <small class="text-muted">by @plugin.Authors</small>
                                }
                            </div>
                            <div class="form-check form-switch ms-2">
                                <input class="form-check-input" type="checkbox" checked="@plugin.Enabled"
                                       @onchange="() => ToggleAsync(plugin)" />
                            </div>
                        </div>
                        <div class="mt-1">
                            <small class="text-muted">@FormatSize(plugin.FileSize)</small>
                            @if (!plugin.Enabled)
                            {
                                <span class="badge bg-secondary ms-1">Disabled</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <!-- Modrinth Browser -->
    <div class="input-group mb-3">
        <input type="text" class="form-control" placeholder="Search for plugins..."
               @bind="_searchQuery" @bind:event="oninput" @onkeydown="HandleSearchKeyDown" />
        <button class="btn btn-primary" @onclick="SearchAsync" disabled="@(string.IsNullOrWhiteSpace(_searchQuery) || _searching)">
            @(_searching ? "Searching..." : "Search")
        </button>
    </div>

    @if (_searchResults.Count > 0)
    {
        <div class="row">
            @foreach (var result in _searchResults)
            {
                <div class="col-md-6 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex gap-3">
                                @if (!string.IsNullOrEmpty(result.IconUrl))
                                {
                                    <img src="@result.IconUrl" alt="" style="width:48px;height:48px;border-radius:8px;" />
                                }
                                <div class="flex-grow-1">
                                    <h6 class="mb-1">@result.Title</h6>
                                    <p class="text-muted small mb-1">@Truncate(result.Description, 120)</p>
                                    <small class="text-muted">by @result.Author - @FormatDownloads(result.Downloads) downloads</small>
                                </div>
                            </div>
                            <div class="mt-2">
                                <button class="btn btn-sm btn-success" @onclick="() => InstallFromModrinthAsync(result)"
                                        disabled="@_installing">
                                    @(_installingId == result.ProjectId ? "Installing..." : "Install Latest")
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_hasSearched)
    {
        <p class="text-muted">No plugins found. Try a different search term.</p>
    }
}

@if (!string.IsNullOrEmpty(_lastResult))
{
    <div class="alert @(_lastResultSuccess ? "alert-success" : "alert-info") alert-dismissible fade show mt-3">
        @_lastResult
        <button type="button" class="btn-close" @onclick="() => _lastResult = null"></button>
    </div>
}

@code {
    private string _tab = "installed";
    private List<PluginInfoDto> _plugins = [];
    private string? _lastResult;
    private bool _lastResultSuccess;

    // Browse
    private string _searchQuery = "";
    private List<ModrinthSearchResultDto> _searchResults = [];
    private bool _searching;
    private bool _hasSearched;
    private bool _installing;
    private string? _installingId;

    // Server control
    private bool _controlBusy;
    private string? _controlAction;

    protected override async Task OnInitializedAsync()
    {
        await Hub.ConnectAsync();
        _plugins = await Hub.GetPluginsAsync();
    }

    private async Task ToggleAsync(PluginInfoDto plugin)
    {
        var result = await Hub.TogglePluginAsync(plugin.FileName);
        _lastResult = result.Message;
        _lastResultSuccess = result.Success;
        _plugins = await Hub.GetPluginsAsync();
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchQuery))
            await SearchAsync();
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery)) return;
        _searching = true;
        _searchResults = await Hub.SearchPluginsAsync(_searchQuery.Trim());
        _searching = false;
        _hasSearched = true;
    }

    private async Task InstallFromModrinthAsync(ModrinthSearchResultDto plugin)
    {
        _installing = true;
        _installingId = plugin.ProjectId;

        var versions = await Hub.GetPluginVersionsAsync(plugin.ProjectId);
        var latest = versions.FirstOrDefault();
        var file = latest?.Files.FirstOrDefault(f => f.Primary) ?? latest?.Files.FirstOrDefault();

        if (file == null)
        {
            _lastResult = $"No compatible version found for {plugin.Title}";
            _lastResultSuccess = false;
            _installing = false;
            _installingId = null;
            return;
        }

        var result = await Hub.InstallPluginAsync(file.Url, file.Filename);
        _lastResult = result.Message;
        _lastResultSuccess = result.Success;
        _installing = false;
        _installingId = null;

        if (result.Success)
            _plugins = await Hub.GetPluginsAsync();
    }

    private async Task RestartServerAsync()
    {
        _controlBusy = true;
        _controlAction = "restart";
        var result = await Hub.RestartServerAsync();
        _lastResult = result.Message;
        _lastResultSuccess = result.Success;
        _controlBusy = false;
        _controlAction = null;
    }

    private async Task StopServerAsync()
    {
        _controlBusy = true;
        _controlAction = "stop";
        var result = await Hub.StopServerAsync();
        _lastResult = result.Message;
        _lastResultSuccess = result.Success;
        _controlBusy = false;
        _controlAction = null;
    }

    private async Task StartServerAsync()
    {
        _controlBusy = true;
        _controlAction = "start";
        var result = await Hub.StartServerAsync();
        _lastResult = result.Message;
        _lastResultSuccess = result.Success;
        _controlBusy = false;
        _controlAction = null;
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F0} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private static string FormatDownloads(long downloads)
    {
        if (downloads >= 1_000_000) return $"{downloads / 1_000_000.0:F1}M";
        if (downloads >= 1_000) return $"{downloads / 1_000.0:F0}K";
        return downloads.ToString();
    }

    private static string Truncate(string text, int maxLength)
    {
        if (text.Length <= maxLength) return text;
        return text[..maxLength] + "...";
    }
}
