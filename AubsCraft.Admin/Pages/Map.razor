@page "/map"
@inject ServerHubClient Hub
@inject InputService Input
@inject WorldCacheService WorldCache
@inject SpawnDev.BlazorJS.WebWorkers.WebWorkerService WorkerService
@inject IJSRuntime JS
@implements IDisposable
@using AubsCraft.Admin.Services
@using SpawnDev.BlazorJS
@using SpawnDev.BlazorJS.JSObjects
@using SpawnDev.BlazorJS.WebWorkers

<PageTitle>Map - AubsCraft Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h1 class="mb-0">World Map</h1>
    <div class="d-flex gap-2 align-items-center">
        @if (_viewMode == ViewMode.Viewer3D)
        {
            <small class="text-muted font-monospace" style="font-size: 0.7rem;">
                @if (_lastStats != null)
                {
                    @($"{_lastStats.Fps:F0} FPS | {_lastStats.VisibleVerts / 1000}K/{_lastStats.TotalVerts / 1000}K verts | {_lastStats.VisibleChunks}/{_lastStats.TotalChunks} chunks | draw: {_lastStats.DrawDistance} | {_lastStats.ChunksPerSecond:F1} c/s | Worker")
                }
                @if (!_pointerLocked) { <span> | Click to fly</span> }
            </small>
            <button class="btn btn-sm btn-outline-secondary" @onclick="SwitchToBlueMap">BlueMap</button>
        }
        else if (_viewMode == ViewMode.BlueMap)
        {
            <button class="btn btn-sm btn-outline-primary" @onclick="SwitchTo3D">3D Viewer</button>
            <a href="@_blueMapUrl" target="_blank" class="btn btn-sm btn-outline-secondary">Open in New Tab</a>
        }
        else
        {
            <span class="text-muted">@_statusMessage</span>
        }
    </div>
</div>

@if (_viewMode == ViewMode.Viewer3D || _viewMode == ViewMode.Initializing)
{
    <canvas id="map-canvas" @ref="_canvasRef"
            style="width: 100%; height: calc(100vh - 8rem); border-radius: 4px; display: block; background: #a5cce8; cursor: @(_pointerLocked ? "none" : "pointer");"
            tabindex="0"
            @onclick="OnCanvasClick"
            @oncontextmenu:preventDefault>
    </canvas>
}
else if (_viewMode == ViewMode.BlueMap && !string.IsNullOrEmpty(_blueMapUrl))
{
    <iframe src="@_blueMapUrl"
            style="width: 100%; height: calc(100vh - 8rem); border: none; border-radius: 4px;"
            allowfullscreen>
    </iframe>
}
else
{
    <div class="alert alert-info">@_statusMessage</div>
}

@code {
    private ElementReference _canvasRef;
    private string? _blueMapUrl;
    private ViewMode _viewMode = ViewMode.Initializing;
    private string _statusMessage = "Initializing...";
    private bool _pointerLocked;

    private WebWorker? _renderWorker;
    private IRenderWorkerService? _renderService;
    private RenderStats? _lastStats;
    private string _renderServiceKey = Guid.NewGuid().ToString();
    private int _lastCanvasW, _lastCanvasH;
    private HTMLCanvasElement? _canvas;
    private ResizeObserver? _resizeObserver;
    private ActionCallback<ResizeObserverEntry[]>? _resizeCallback;

    private enum ViewMode { Initializing, Viewer3D, BlueMap, Error }

    protected override async Task OnInitializedAsync()
    {
        await Hub.ConnectAsync();
        Hub.OnServerStatusReceived += OnServerStatus;
        var config = await Hub.GetBlueMapConfigAsync();
        if (config.Enabled && !string.IsNullOrEmpty(config.Url))
            _blueMapUrl = config.Url;
    }

    private void OnServerStatus(ServerStatusDto status)
    {
        if (status.TimeTicks >= 0 && _renderService != null)
            _ = _renderService.SetTimeOfDay(status.TimeTicks);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            _statusMessage = "Starting render worker...";
            StateHasChanged();

            // Create a dedicated Web Worker for the entire render pipeline
            _renderWorker = await WorkerService.GetWebWorker();

            System.Console.WriteLine("[Map] Render worker created, transferring canvas...");

            // Transfer the canvas to the worker - worker now owns GPU rendering
            _canvas = new HTMLCanvasElement(_canvasRef);
            int width = _canvas.ClientWidth;
            int height = _canvas.ClientHeight;
            _lastCanvasW = width;
            _lastCanvasH = height;
            _canvas.Width = width;
            _canvas.Height = height;
            var offscreen = _canvas.TransferControlToOffscreen();

            // ResizeObserver fires ONLY when size changes
            _resizeCallback = new ActionCallback<ResizeObserverEntry[]>(OnCanvasResized);
            _resizeObserver = new ResizeObserver(_resizeCallback);
            _resizeObserver.Observe(_canvasRef);

            // Create RenderWorkerService in the worker using New() expression
            // OffscreenCanvas is transferred, DI services injected via [FromServices]
            await _renderWorker.New<IRenderWorkerService>(_renderServiceKey,
                () => new RenderWorkerService(offscreen, width, height));
            _renderService = _renderWorker.GetKeyedService<IRenderWorkerService>(_renderServiceKey);

            // Attach input service on main thread
            Input.Attach();

            // Track pointer lock changes
            await JS.InvokeVoidAsync("eval", @"
                document.addEventListener('pointerlockchange', function() {
                    window.__mapLocked = !!document.pointerLockElement;
                });
                window.__mapLocked = false;
            ");

            // Restore camera position
            float camX = 0f, camY = 200f, camZ = 0f, pitch = -90f, yaw = 0f;
            var savedCam = await WorldCache.LoadCameraPositionAsync();
            if (savedCam != null)
            {
                (camX, camY, camZ, pitch, yaw) = savedCam.Value;
                System.Console.WriteLine($"[Map] Restored camera: ({camX:F0}, {camY:F0}, {camZ:F0})");
            }

            // Start render loop + chunk loading in the worker
            await _renderService.StartAsync(camX, camY, camZ, pitch, yaw);

            _viewMode = ViewMode.Viewer3D;
            _statusMessage = "";
            StateHasChanged();

            // Main thread: input + stats only
            _ = InputAndStatsLoop();
        }
        catch (Exception ex)
        {
            _viewMode = ViewMode.Error;
            _statusMessage = $"GPU init failed: {ex.Message}";
            System.Console.WriteLine($"[Map] Init error: {ex}");
            if (!string.IsNullOrEmpty(_blueMapUrl))
            {
                _viewMode = ViewMode.BlueMap;
                _statusMessage = "GPU not available, using BlueMap";
            }
            StateHasChanged();
        }
    }

    /// <summary>
    /// Main thread loop: sends input to the worker, receives stats back.
    /// Zero rendering, zero GPU work, zero data processing.
    /// </summary>
    private async Task InputAndStatsLoop()
    {
        int cameraSaveCounter = 0;
        while (_viewMode == ViewMode.Viewer3D && _renderService != null)
        {
            await Task.Delay(16);

            bool browserLocked = ((IJSInProcessRuntime)JS).Invoke<bool>("eval", "!!window.__mapLocked");
            if (_pointerLocked && !browserLocked)
            {
                _pointerLocked = false;
                Input.ConsumeMouseDelta();
            }
            _pointerLocked = browserLocked;

            if (_pointerLocked)
            {
                if (Input.KeysDown.Contains("Escape"))
                {
                    _pointerLocked = false;
                    Input.KeysDown.Remove("Escape");
                    continue;
                }

                var (dx, dy) = Input.ConsumeMouseDelta();
                var keysDown = Input.KeysDown;
                if (dx != 0 || dy != 0 || keysDown.Count > 0)
                    await _renderService.ProcessInputAsync(dx, dy, 0.016f, keysDown.ToArray());
            }

            cameraSaveCounter++;
            if (cameraSaveCounter >= 30)
            {
                cameraSaveCounter = 0;
                _lastStats = await _renderService.GetStatsAsync();
                StateHasChanged();

                if (_lastStats != null)
                    _ = WorldCache.SaveCameraPositionAsync(
                        _lastStats.CamX, _lastStats.CamY, _lastStats.CamZ,
                        _lastStats.CamPitch, _lastStats.CamYaw);
            }
        }
    }

    private void OnCanvasResized(ResizeObserverEntry[] entries)
    {
        if (_canvas == null || _renderService == null) return;
        int cw = _canvas.ClientWidth;
        int ch = _canvas.ClientHeight;
        if (cw > 0 && ch > 0 && (cw != _lastCanvasW || ch != _lastCanvasH))
        {
            _lastCanvasW = cw;
            _lastCanvasH = ch;
            _ = _renderService.ResizeAsync(cw, ch);
        }
        foreach (var e in entries) e.Dispose();
    }

    private async void OnCanvasClick()
    {
        if (_pointerLocked) return;
        try
        {
            await JS.InvokeVoidAsync("eval", "document.getElementById('map-canvas')?.requestPointerLock()");
        }
        catch { }
    }

    private void SwitchTo3D() => _viewMode = ViewMode.Viewer3D;
    private void SwitchToBlueMap() => _viewMode = ViewMode.BlueMap;

    public void Dispose()
    {
        _resizeObserver?.Disconnect();
        _resizeObserver?.Dispose();
        _resizeCallback?.Dispose();
        _renderWorker?.Dispose();
        _canvas?.Dispose();
        Input.Detach();
    }
}
