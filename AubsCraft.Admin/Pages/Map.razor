@page "/map"
@inject ServerHubClient Hub
@inject HttpClient Http
@inject VoxelEngineService Engine
@inject InputService Input
@inject AubsCraft.Admin.Rendering.MapRenderService Renderer
@inject IJSRuntime JS
@implements IDisposable
@using AubsCraft.Admin.Rendering
@using SpawnDev.BlazorJS.JSObjects

<PageTitle>Map - AubsCraft Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h1 class="mb-0">World Map</h1>
    <div class="d-flex gap-2 align-items-center">
        @if (_viewMode == ViewMode.Viewer3D)
        {
            <small class="text-muted font-monospace" style="font-size: 0.7rem;">
                @Renderer.Fps.ToString("F0") FPS (@Renderer.FrameTimeMs.ToString("F1")ms) |
                @(Renderer.VisibleVertices / 1000)K/@(Renderer.TotalVertices / 1000)K verts |
                @Renderer.VisibleChunkCount/@Renderer.TotalChunkCount chunks |
                draw: @Renderer.DrawDistance |
                @(Engine.BackendName ?? "...")
                @if (!_pointerLocked) { <span> | Click to fly</span> }
            </small>
            <button class="btn btn-sm btn-outline-secondary" @onclick="SwitchToBlueMap">BlueMap</button>
        }
        else if (_viewMode == ViewMode.BlueMap)
        {
            <button class="btn btn-sm btn-outline-primary" @onclick="SwitchTo3D">3D Viewer</button>
            <a href="@_blueMapUrl" target="_blank" class="btn btn-sm btn-outline-secondary">Open in New Tab</a>
        }
        else
        {
            <span class="text-muted">@_statusMessage</span>
        }
    </div>
</div>

@if (_viewMode == ViewMode.Viewer3D || _viewMode == ViewMode.Initializing)
{
    <canvas id="map-canvas" @ref="_canvasRef"
            style="width: 100%; height: calc(100vh - 8rem); border-radius: 4px; display: block; background: #a5cce8; cursor: @(_pointerLocked ? "none" : "pointer");"
            tabindex="0"
            @onclick="OnCanvasClick"
            @oncontextmenu:preventDefault>
    </canvas>
}
else if (_viewMode == ViewMode.BlueMap && !string.IsNullOrEmpty(_blueMapUrl))
{
    <iframe src="@_blueMapUrl"
            style="width: 100%; height: calc(100vh - 8rem); border: none; border-radius: 4px;"
            allowfullscreen>
    </iframe>
}
else
{
    <div class="alert alert-info">@_statusMessage</div>
}

@code {
    private ElementReference _canvasRef;
    private string? _blueMapUrl;
    private ViewMode _viewMode = ViewMode.Initializing;
    private string _statusMessage = "Initializing GPU...";
    private int _loadedCount;
    private bool _pointerLocked;
    private HashSet<(int, int)> _populatedChunks = new();
    private HashSet<(int, int)> _loadedChunks = new();
    private HashSet<(int, int)> _loadingChunks = new();
    private List<(int cx, int cz)> _playerChunkKeys = new();

    private enum ViewMode { Initializing, Viewer3D, BlueMap, Error }

    protected override async Task OnInitializedAsync()
    {
        await Hub.ConnectAsync();
        var config = await Hub.GetBlueMapConfigAsync();
        if (config.Enabled && !string.IsNullOrEmpty(config.Url))
            _blueMapUrl = config.Url;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            _statusMessage = "Initializing GPU...";
            StateHasChanged();

            await Engine.InitAsync();

            using var canvas = new HTMLCanvasElement(_canvasRef);
            Renderer.Init(canvas, Engine.Accelerator!);

            // Attach input service for keyboard/mouse
            Input.Attach();

            // Process input each frame
            Renderer.OnUpdate = OnFrameUpdate;

            // Track pointer lock changes via JS callback
            await JS.InvokeVoidAsync("eval", @"
                document.addEventListener('pointerlockchange', function() {
                    window.__mapLocked = !!document.pointerLockElement;
                });
                window.__mapLocked = false;
            ");

            _viewMode = ViewMode.Viewer3D;
            _statusMessage = "";
            StateHasChanged();

            Renderer.StartRenderLoop();
            _ = LoadAtlasAsync();
            _ = LoadInitialChunksAsync();
            _ = StatsRefreshLoop();
        }
        catch (Exception ex)
        {
            _viewMode = ViewMode.Error;
            _statusMessage = $"GPU init failed: {ex.Message}";
            if (!string.IsNullOrEmpty(_blueMapUrl))
            {
                _viewMode = ViewMode.BlueMap;
                _statusMessage = "GPU not available, using BlueMap";
            }
            StateHasChanged();
        }
    }

    private int _lastFullCX = int.MinValue, _lastFullCZ = int.MinValue;
    private bool _loadingFull;

    private void OnFrameUpdate(float dt)
    {
        var (dx, dy) = Input.ConsumeMouseDelta();
        if (_pointerLocked && (dx != 0 || dy != 0))
            Renderer.Camera.ProcessMouseMovement(dx, dy);

        if (_pointerLocked)
            Renderer.Camera.ProcessKeyboard(Input.KeysDown, dt);

        if (_pointerLocked && Input.KeysDown.Contains("Escape"))
        {
            _pointerLocked = false;
            Input.KeysDown.Remove("Escape");
        }

        // Dynamic full-3D loading for nearby chunks
        int camCX = (int)MathF.Floor(Renderer.Camera.Position.X / 16f);
        int camCZ = (int)MathF.Floor(Renderer.Camera.Position.Z / 16f);
        if (!_loadingFull && (camCX != _lastFullCX || camCZ != _lastFullCZ))
        {
            _lastFullCX = camCX;
            _lastFullCZ = camCZ;
            _ = LoadFullChunksNearbyAsync(camCX, camCZ);
        }
    }

    private async void OnCanvasClick()
    {
        if (_pointerLocked) return;
        try
        {
            await JS.InvokeVoidAsync("eval", "document.getElementById('map-canvas')?.requestPointerLock()");
            _pointerLocked = true;
        }
        catch { } // Browser rejects if too soon after ESC - silently ignore
    }

    private async Task LoadInitialChunksAsync()
    {
        try
        {
            // Start high up looking down - map view
            Renderer.Camera.Position = new System.Numerics.Vector3(0f, 200f, 0f);
            Renderer.Camera.Pitch = -90f; // Look straight down
            Renderer.Camera.Yaw = 0f;

            // Stream heightmaps for the entire world - lightweight, fast
            System.Console.WriteLine("[Map] Streaming heightmaps...");
            await foreach (var hm in Hub.StreamHeightmaps())
            {
                try
                {
                    _populatedChunks.Add((hm.X, hm.Z));

                    var heightBytes = Convert.FromBase64String(hm.Heights);
                    var heights = new int[heightBytes.Length / 4];
                    Buffer.BlockCopy(heightBytes, 0, heights, 0, heightBytes.Length);

                    var blockIdBytes = Convert.FromBase64String(hm.BlockIds);
                    var blockIds = new ushort[blockIdBytes.Length / 2];
                    Buffer.BlockCopy(blockIdBytes, 0, blockIds, 0, blockIdBytes.Length);

                    var paletteColors = BlockColorMap.BuildPaletteColors(hm.Palette);

                    var (vertices, vertexCount) = HeightmapMesher.GenerateMesh(
                        heights, blockIds, paletteColors, hm.Palette, hm.X, hm.Z);

                    if (vertexCount > 0)
                    {
                        Renderer.UploadChunkMesh(hm.X, hm.Z, vertices);
                        _loadedChunks.Add((hm.X, hm.Z));
                        _loadedCount++;
                        if (_loadedCount % 10 == 0) StateHasChanged();
                    }
                }
                catch (Exception ex)
                {
                    System.Console.WriteLine($"[Map] Heightmap ({hm.X},{hm.Z}) error: {ex.Message}");
                }
                // Yield periodically to keep render loop and SignalR connection alive
                if (_loadedCount % 5 == 0)
                    await Task.Yield();
            }
            System.Console.WriteLine($"[Map] Loaded {_loadedCount} heightmap chunks");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            System.Console.WriteLine($"[Map] Stream error: {ex.Message}");
        }
    }

    private async Task StatsRefreshLoop()
    {
        while (_viewMode == ViewMode.Viewer3D)
        {
            await Task.Delay(500);

            // Update player positions
            try
            {
                var positions = await Hub.GetPlayerPositionsAsync();
                UpdatePlayerMarkers(positions);
            }
            catch { }

            StateHasChanged();
        }
    }

    private void UpdatePlayerMarkers(List<PlayerPositionDto> positions)
    {
        // Remove old markers
        foreach (var key in _playerChunkKeys)
            Renderer.RemoveChunkMesh(key.cx, key.cz);
        _playerChunkKeys.Clear();

        foreach (var pos in positions)
        {
            // Create a bright colored beacon column at player position
            var verts = new List<float>();
            float px = pos.X;
            float py = pos.Y;
            float pz = pos.Z;

            // Render a 1x3 colored pillar (visible from distance)
            for (int dy = 0; dy < 5; dy++)
            {
                float y = py + dy;
                // Bright cyan marker
                float r = 0.1f, g = 0.9f, b = 1.0f;
                // All 6 faces of the marker block
                EmitMarkerBlock(verts, px, y, pz, r, g, b);
            }

            // Use a unique chunk key far outside normal range
            int markerCx = 100000 + _playerChunkKeys.Count;
            int markerCz = 100000;
            _playerChunkKeys.Add((markerCx, markerCz));

            if (verts.Count > 0)
                Renderer.UploadChunkMesh(markerCx, markerCz, verts.ToArray());
        }
    }

    private static void EmitMarkerBlock(List<float> v, float x, float y, float z, float r, float g, float b)
    {
        float s = 0.5f; // half-size
        float x0 = x - s, x1 = x + s, z0 = z - s, z1 = z + s;
        float y0 = y, y1 = y + 1;
        float nu = -1f; // no texture

        // Top
        MV(v, x0, y1, z0, 0, 1, 0, r, g, b, nu, nu); MV(v, x0, y1, z1, 0, 1, 0, r, g, b, nu, nu);
        MV(v, x1, y1, z1, 0, 1, 0, r, g, b, nu, nu); MV(v, x0, y1, z0, 0, 1, 0, r, g, b, nu, nu);
        MV(v, x1, y1, z1, 0, 1, 0, r, g, b, nu, nu); MV(v, x1, y1, z0, 0, 1, 0, r, g, b, nu, nu);
        // -X
        MV(v, x0, y0, z1, -1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu); MV(v, x0, y1, z1, -1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu);
        MV(v, x0, y1, z0, -1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu); MV(v, x0, y0, z1, -1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu);
        MV(v, x0, y1, z0, -1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu); MV(v, x0, y0, z0, -1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu);
        // +X
        MV(v, x1, y0, z0, 1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu); MV(v, x1, y1, z0, 1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu);
        MV(v, x1, y1, z1, 1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu); MV(v, x1, y0, z0, 1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu);
        MV(v, x1, y1, z1, 1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu); MV(v, x1, y0, z1, 1, 0, 0, r*0.8f, g*0.8f, b*0.8f, nu, nu);
        // -Z
        MV(v, x0, y0, z0, 0, 0, -1, r*0.7f, g*0.7f, b*0.7f, nu, nu); MV(v, x0, y1, z0, 0, 0, -1, r*0.7f, g*0.7f, b*0.7f, nu, nu);
        MV(v, x1, y1, z0, 0, 0, -1, r*0.7f, g*0.7f, b*0.7f, nu, nu); MV(v, x0, y0, z0, 0, 0, -1, r*0.7f, g*0.7f, b*0.7f, nu, nu);
        MV(v, x1, y1, z0, 0, 0, -1, r*0.7f, g*0.7f, b*0.7f, nu, nu); MV(v, x1, y0, z0, 0, 0, -1, r*0.7f, g*0.7f, b*0.7f, nu, nu);
        // +Z
        MV(v, x1, y0, z1, 0, 0, 1, r*0.7f, g*0.7f, b*0.7f, nu, nu); MV(v, x1, y1, z1, 0, 0, 1, r*0.7f, g*0.7f, b*0.7f, nu, nu);
        MV(v, x0, y1, z1, 0, 0, 1, r*0.7f, g*0.7f, b*0.7f, nu, nu); MV(v, x1, y0, z1, 0, 0, 1, r*0.7f, g*0.7f, b*0.7f, nu, nu);
        MV(v, x0, y1, z1, 0, 0, 1, r*0.7f, g*0.7f, b*0.7f, nu, nu); MV(v, x0, y0, z1, 0, 0, 1, r*0.7f, g*0.7f, b*0.7f, nu, nu);
    }

    private static void MV(List<float> v, float px, float py, float pz, float nx, float ny, float nz, float r, float g, float b, float u, float uv)
    {
        v.Add(px); v.Add(py); v.Add(pz);
        v.Add(nx); v.Add(ny); v.Add(nz);
        v.Add(r); v.Add(g); v.Add(b);
        v.Add(u); v.Add(uv);
    }

    private async Task LoadAtlasAsync()
    {
        try
        {
            // Load pre-decoded RGBA atlas data from server
            var rgba = await Http.GetByteArrayAsync("atlas.rgba");
            // Atlas is square: side = sqrt(totalBytes / 4)
            int size = (int)Math.Sqrt(rgba.Length / 4);
            Renderer.UploadAtlas(rgba, size, size);
        }
        catch (Exception ex)
        {
            System.Console.WriteLine($"[Map] Atlas load error: {ex.Message}");
        }
    }

    private HashSet<(int, int)> _fullChunks = new();
    private const int FullRenderRadius = 3;

    private async Task LoadFullChunksNearbyAsync(int camCX, int camCZ)
    {
        _loadingFull = true;
        try
        {
            for (int dz = -FullRenderRadius; dz <= FullRenderRadius; dz++)
            for (int dx = -FullRenderRadius; dx <= FullRenderRadius; dx++)
            {
                if (dx * dx + dz * dz > FullRenderRadius * FullRenderRadius) continue;
                int cx = camCX + dx;
                int cz = camCZ + dz;
                if (_fullChunks.Contains((cx, cz))) continue;
                if (!_populatedChunks.Contains((cx, cz))) continue;

                try
                {
                    var response = await Http.GetAsync($"/api/world/chunk/{cx}/{cz}");
                    if (!response.IsSuccessStatusCode) continue;

                    var chunkData = await response.Content.ReadFromJsonAsync<ChunkDataDto>();
                    if (chunkData == null) continue;

                    var blockBytes = Convert.FromBase64String(chunkData.Blocks);
                    var blocks = new ushort[blockBytes.Length / 2];
                    Buffer.BlockCopy(blockBytes, 0, blocks, 0, blockBytes.Length);
                    if (blocks.Length != 16 * 384 * 16) continue;

                    var paletteColors = BlockColorMap.BuildPaletteColors(chunkData.Palette);
                    var result = await Engine.GenerateMeshAsync(blocks, paletteColors, cx, cz);

                    if (result.VertexCount > 0)
                    {
                        Renderer.UploadChunkMesh(cx, cz, result.Vertices);
                        _fullChunks.Add((cx, cz));
                    }
                }
                catch { }
                await Task.Yield();
            }
        }
        finally
        {
            _loadingFull = false;
        }
    }

    private void SwitchTo3D() => _viewMode = ViewMode.Viewer3D;
    private void SwitchToBlueMap() => _viewMode = ViewMode.BlueMap;

    public void Dispose()
    {
        Renderer.StopRenderLoop();
        Input.Detach();
    }

    private record ChunkCoordDto(int X, int Z);
    private record ChunkDataDto(string Blocks, List<string> Palette);
}
