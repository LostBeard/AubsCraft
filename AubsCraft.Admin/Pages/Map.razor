@page "/map"
@inject ServerHubClient Hub
@inject HttpClient Http
@inject VoxelEngineService Engine
@inject InputService Input
@inject AubsCraft.Admin.Rendering.MapRenderService Renderer
@inject IJSRuntime JS
@implements IDisposable
@using AubsCraft.Admin.Rendering
@using SpawnDev.BlazorJS.JSObjects

<PageTitle>Map - AubsCraft Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h1 class="mb-0">World Map</h1>
    <div class="d-flex gap-2 align-items-center">
        @if (_viewMode == ViewMode.Viewer3D)
        {
            <small class="text-muted">
                @(Engine.BackendName ?? "...") |
                @Renderer.VisibleChunkCount/@Renderer.TotalChunkCount chunks |
                @_loadedCount loaded
                @if (!_pointerLocked) { <span> | Click to fly</span> }
                else { <span> | WASD + Mouse | ESC to release</span> }
            </small>
            <button class="btn btn-sm btn-outline-secondary" @onclick="SwitchToBlueMap">BlueMap</button>
        }
        else if (_viewMode == ViewMode.BlueMap)
        {
            <button class="btn btn-sm btn-outline-primary" @onclick="SwitchTo3D">3D Viewer</button>
            <a href="@_blueMapUrl" target="_blank" class="btn btn-sm btn-outline-secondary">Open in New Tab</a>
        }
        else
        {
            <span class="text-muted">@_statusMessage</span>
        }
    </div>
</div>

@if (_viewMode == ViewMode.Viewer3D || _viewMode == ViewMode.Initializing)
{
    <canvas id="map-canvas" @ref="_canvasRef"
            style="width: 100%; height: calc(100vh - 8rem); border-radius: 4px; display: block; background: #a5cce8; cursor: @(_pointerLocked ? "none" : "pointer");"
            tabindex="0"
            @onclick="OnCanvasClick"
            @oncontextmenu:preventDefault>
    </canvas>
}
else if (_viewMode == ViewMode.BlueMap && !string.IsNullOrEmpty(_blueMapUrl))
{
    <iframe src="@_blueMapUrl"
            style="width: 100%; height: calc(100vh - 8rem); border: none; border-radius: 4px;"
            allowfullscreen>
    </iframe>
}
else
{
    <div class="alert alert-info">@_statusMessage</div>
}

@code {
    private ElementReference _canvasRef;
    private string? _blueMapUrl;
    private ViewMode _viewMode = ViewMode.Initializing;
    private string _statusMessage = "Initializing GPU...";
    private int _loadedCount;
    private bool _pointerLocked;
    private HashSet<(int, int)> _populatedChunks = new();
    private HashSet<(int, int)> _loadedChunks = new();
    private HashSet<(int, int)> _loadingChunks = new();

    private enum ViewMode { Initializing, Viewer3D, BlueMap, Error }

    protected override async Task OnInitializedAsync()
    {
        await Hub.ConnectAsync();
        var config = await Hub.GetBlueMapConfigAsync();
        if (config.Enabled && !string.IsNullOrEmpty(config.Url))
            _blueMapUrl = config.Url;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            _statusMessage = "Initializing GPU...";
            StateHasChanged();

            await Engine.InitAsync();

            using var canvas = new HTMLCanvasElement(_canvasRef);
            Renderer.Init(canvas, Engine.Accelerator!);

            // Attach input service for keyboard/mouse
            Input.Attach();

            // Process input each frame
            Renderer.OnUpdate = OnFrameUpdate;

            // Listen for pointer lock changes
            await JS.InvokeVoidAsync("eval", @"
                document.addEventListener('pointerlockchange', function() {
                    window.__mapPointerLocked = !!document.pointerLockElement;
                });
                window.__mapPointerLocked = false;
            ");

            _viewMode = ViewMode.Viewer3D;
            _statusMessage = "";
            StateHasChanged();

            Renderer.StartRenderLoop();
            _ = LoadInitialChunksAsync();
        }
        catch (Exception ex)
        {
            _viewMode = ViewMode.Error;
            _statusMessage = $"GPU init failed: {ex.Message}";
            if (!string.IsNullOrEmpty(_blueMapUrl))
            {
                _viewMode = ViewMode.BlueMap;
                _statusMessage = "GPU not available, using BlueMap";
            }
            StateHasChanged();
        }
    }

    private void OnFrameUpdate(float dt)
    {
        var (dx, dy) = Input.ConsumeMouseDelta();
        if (_pointerLocked && (dx != 0 || dy != 0))
            Renderer.Camera.ProcessMouseMovement(dx, dy);

        if (_pointerLocked)
            Renderer.Camera.ProcessKeyboard(Input.KeysDown, dt);

        try
        {
            _pointerLocked = ((IJSInProcessRuntime)JS).Invoke<bool>("eval", "window.__mapPointerLocked || false");
        }
        catch { }

    }

    private async void OnCanvasClick()
    {
        if (!_pointerLocked)
        {
            await JS.InvokeVoidAsync("eval", "document.getElementById('map-canvas')?.requestPointerLock()");
            _pointerLocked = true;
        }
    }

    private async Task LoadInitialChunksAsync()
    {
        try
        {
            // Start high up looking down - map view
            Renderer.Camera.Position = new System.Numerics.Vector3(0f, 200f, 0f);
            Renderer.Camera.Pitch = -90f; // Look straight down
            Renderer.Camera.Yaw = 0f;

            // Stream heightmaps for the entire world - lightweight, fast
            System.Console.WriteLine("[Map] Streaming heightmaps...");
            await foreach (var hm in Hub.StreamHeightmaps())
            {
                try
                {
                    _populatedChunks.Add((hm.X, hm.Z));

                    var heightBytes = Convert.FromBase64String(hm.Heights);
                    var heights = new int[heightBytes.Length / 4];
                    Buffer.BlockCopy(heightBytes, 0, heights, 0, heightBytes.Length);

                    var blockIdBytes = Convert.FromBase64String(hm.BlockIds);
                    var blockIds = new ushort[blockIdBytes.Length / 2];
                    Buffer.BlockCopy(blockIdBytes, 0, blockIds, 0, blockIdBytes.Length);

                    var paletteColors = BlockColorMap.BuildPaletteColors(hm.Palette);

                    var (vertices, vertexCount) = HeightmapMesher.GenerateMesh(
                        heights, blockIds, paletteColors, hm.Palette, hm.X, hm.Z);

                    if (vertexCount > 0)
                    {
                        Renderer.UploadChunkMesh(hm.X, hm.Z, vertices);
                        _loadedChunks.Add((hm.X, hm.Z));
                        _loadedCount++;
                        if (_loadedCount % 10 == 0) StateHasChanged();
                    }
                }
                catch (Exception ex)
                {
                    System.Console.WriteLine($"[Map] Heightmap ({hm.X},{hm.Z}) error: {ex.Message}");
                }
            }
            System.Console.WriteLine($"[Map] Loaded {_loadedCount} heightmap chunks");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            System.Console.WriteLine($"[Map] Stream error: {ex.Message}");
        }
    }

    private void SwitchTo3D() => _viewMode = ViewMode.Viewer3D;
    private void SwitchToBlueMap() => _viewMode = ViewMode.BlueMap;

    public void Dispose()
    {
        Renderer.StopRenderLoop();
        Input.Detach();
    }

    private record ChunkCoordDto(int X, int Z);
    private record ChunkDataDto(string Blocks, List<string> Palette);
}
