@page "/account"
@inject ServerHubClient Hub
@inject AuthStateProvider Auth
@implements IDisposable

<PageTitle>My Account - AubsCraft</PageTitle>

<h1>My Account</h1>

<div class="card mb-3">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <div class="text-muted small">Username</div>
                <div class="h5">@Auth.Username</div>
            </div>
            <div class="col-md-6">
                <div class="text-muted small">Role</div>
                <div class="h5">@Auth.Role</div>
            </div>
        </div>
    </div>
</div>

<h3 class="mt-4">My Minecraft Accounts</h3>
<p class="text-muted small">
    Add your Minecraft username here so you can join the server. Java for PC, Bedrock for phone/Switch/Xbox.
    @if (Auth.IsFriend)
    {
        <span>You can add up to 5 accounts.</span>
    }
</p>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small">Minecraft Username</label>
                <input type="text" class="form-control" @bind="_newMc" @bind:event="oninput"
                       placeholder="e.g. SpudArt" @onkeydown="OnEnter" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Platform</label>
                <select class="form-select" @bind="_newPlatform">
                    <option value="Java">Java (PC)</option>
                    <option value="Bedrock">Bedrock (phone/Switch/Xbox)</option>
                </select>
            </div>
            <div class="col-md-4">
                <button class="btn btn-primary w-100" @onclick="AddAsync" disabled="@_busy">
                    @(_busy ? "Adding..." : "Add to Whitelist")
                </button>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert alert-@_messageClass mt-2 mb-0 py-2 small">@_message</div>
        }
    </div>
</div>

@if (_accounts == null)
{
    <p class="text-muted">Loading...</p>
}
else if (_accounts.Count == 0)
{
    <p class="text-muted">You haven't added any Minecraft accounts yet.</p>
}
else
{
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Username</th>
                <th>Platform</th>
                <th>Added</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in _accounts)
            {
                <tr>
                    <td>
                        <img src="@AvatarUrl(entry)" alt="@entry.McUsername" class="rounded me-2"
                             style="width:24px;height:24px;" />
                        <strong>@entry.McUsername</strong>
                    </td>
                    <td><span class="badge bg-secondary">@entry.Platform</span></td>
                    <td class="text-muted small">@entry.AddedAt.ToLocalTime().ToString("g")</td>
                    <td class="text-end"></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<WhitelistAuditEntryDto>? _accounts;
    private string _newMc = "";
    private string _newPlatform = "Java";
    private string? _message;
    private string _messageClass = "info";
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        await Hub.ConnectAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _accounts = await Hub.GetMyMcAccountsAsync();
        StateHasChanged();
    }

    private async Task OnEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddAsync();
    }

    private async Task AddAsync()
    {
        _message = null;
        if (string.IsNullOrWhiteSpace(_newMc))
        {
            _message = "Enter a Minecraft username.";
            _messageClass = "warning";
            return;
        }
        _busy = true;
        var result = await Hub.AddOwnMcAccountAsync(_newMc.Trim(), _newPlatform);
        _busy = false;
        _message = result.Message;
        _messageClass = result.Success ? "success" : "danger";
        if (result.Success)
        {
            _newMc = "";
            await LoadAsync();
        }
    }

    private static string AvatarUrl(WhitelistAuditEntryDto e)
        => $"https://mc-heads.net/avatar/{e.McUsername}/24";

    public void Dispose() { }
}
