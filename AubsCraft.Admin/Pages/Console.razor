@page "/console"
@inject ServerHubClient Hub
@inject SpawnDev.BlazorJS.BlazorJSRuntime JS
@using SpawnDev.BlazorJS.JSObjects

<PageTitle>Console - AubsCraft Admin</PageTitle>

<h1>Server Console</h1>

<p class="text-muted">Send commands directly to the Minecraft server. Use arrow keys to recall previous commands.</p>

<div class="card mb-4">
    <div class="card-body">
        <div class="input-group">
            <span class="input-group-text">/</span>
            <input type="text" class="form-control" placeholder="Type a command..."
                   @bind="_command" @bind:event="oninput" @onkeydown="HandleKeyDown" />
            <button class="btn btn-primary" @onclick="SendCommandAsync" disabled="@string.IsNullOrWhiteSpace(_command)">
                Send
            </button>
        </div>
    </div>
</div>

@if (_history.Count > 0)
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Command History</h5>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearHistory">Clear</button>
        </div>
        <div class="card-body p-0">
            <div @ref="_outputRef" class="console-output font-monospace p-3">
                @foreach (var entry in _history)
                {
                    <div class="mb-1">
                        <span class="console-prompt">&gt; /@entry.Command</span>
                    </div>
                    <div class="mb-2">
                        @if (string.IsNullOrEmpty(entry.Response))
                        {
                            <em class="console-muted">(no response)</em>
                        }
                        else
                        {
                            <span class="console-response">@entry.Response</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private string _command = "";
    private List<ConsoleEntry> _history = [];
    private List<string> _commandHistory = [];
    private int _historyIndex = -1;
    private ElementReference _outputRef;

    protected override async Task OnInitializedAsync()
    {
        await Hub.ConnectAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_command))
        {
            await SendCommandAsync();
        }
        else if (e.Key == "ArrowUp" && _commandHistory.Count > 0)
        {
            if (_historyIndex < _commandHistory.Count - 1)
                _historyIndex++;
            _command = _commandHistory[_commandHistory.Count - 1 - _historyIndex];
        }
        else if (e.Key == "ArrowDown")
        {
            if (_historyIndex > 0)
            {
                _historyIndex--;
                _command = _commandHistory[_commandHistory.Count - 1 - _historyIndex];
            }
            else
            {
                _historyIndex = -1;
                _command = "";
            }
        }
    }

    private async Task SendCommandAsync()
    {
        if (string.IsNullOrWhiteSpace(_command)) return;
        var cmd = _command.Trim();
        _command = "";
        _historyIndex = -1;
        _commandHistory.Add(cmd);

        var response = await Hub.SendCommandAsync(cmd);
        _history.Add(new ConsoleEntry(cmd, response));

        await ScrollToBottom();
    }

    private void ClearHistory()
    {
        _history.Clear();
    }

    private async Task ScrollToBottom()
    {
        await Task.Yield();
        try
        {
            using var doc = JS.Get<Document>("document");
            using var el = doc.QuerySelector(".console-output");
            if (el != null)
                el.ScrollTop = el.ScrollHeight;
        }
        catch { }
    }

    private record ConsoleEntry(string Command, string Response);
}
